# Copy this file to .env and fill in real values before going live.

PORT=4000

# Powers the AI reasoning engine (discovery interview interpretation + growth report).
# Without this, the server automatically falls back to rule-based logic — everything
# still works, just without real AI reasoning.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-5

# Optional: a SERP / search API for real competitor discovery
# (e.g. SerpAPI, Bing Web Search, or a custom scraper key).
SEARCH_API_KEY=

# Admin panel login (used by storesage-frontend/admin.html).
# Pick a real username and a strong password before deploying — these are
# compared in plain text right now, which is fine for a local/student project
# but should be upgraded (hashed password, JWT with expiry) before production.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123
